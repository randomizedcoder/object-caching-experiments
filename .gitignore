# Ignore build outputs from performing a nix-build or `nix build` command
result
result-*

# Per-VM writable disks + QEMU sockets (regenerated by cache-start-all)
*.img
*-data.img
*.sock

# Generated config snapshots dumped by cache-render for inspection
rendered/

# Pre-generated material under ./secrets/ (SSH keys; later, CA trees).
#
# Deliberately NOT gitignored. A pure Nix flake can only read files Git
# knows about, so to bake host keys into VM images and the user pubkey
# into authorized_keys, secrets/ must be visible to the flake. We make it
# visible with `git add --intent-to-add` (run by cache-gen-secrets), which
# keeps the content on disk but stores an EMPTY blob in the index — so even
# `git commit -a` commits empty stubs, never the key material.
#
# A manual `git add secrets/` followed by a commit WOULD leak private keys.
# Therefore: *** NEVER run plain `git add` on anything under secrets/ ***
# cache-gen-secrets does the `git add --intent-to-add` itself.

# Ignore automatically generated direnv output
.direnv

# Ignore NixOS interactive test driver history
**/.nixos-test-history

# Local-only tooling / data — never part of the repo
.claude/
usage-data/
